<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.HardwarePage"
             Title="Hardware Demo">
    <ScrollView>
        <ScrollView.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{AppThemeBinding Light=#E8F4F8, Dark=#0A1628}" Offset="0.0" />
                <GradientStop Color="{AppThemeBinding Light=#F0F7FA, Dark=#0D1B2A}" Offset="1.0" />
            </LinearGradientBrush>
        </ScrollView.Background>

        <VerticalStackLayout Padding="22" Spacing="16">
            <Border StrokeThickness="0" Padding="18" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#162535}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="6">
                    <Label Text="Mobile hardware"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#1B2838, Dark=#E8F0F8}"
                           SemanticProperties.HeadingLevel="Level1" />
                    <Label Text="Demonstrate camera, location, speech, vibration, and haptic feedback."
                           FontSize="15"
                           TextColor="{AppThemeBinding Light=#5B7288, Dark=#8BA4BE}" />
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#D0E4EE, Dark=#2A4055}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#162535}"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="14">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="3">
                            <Label Text="Food photo" FontSize="17" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#2E86AB, Dark=#5BC0EB}" />
                            <Label Text="Capture the colour and condition of the meal." FontSize="13" TextColor="{AppThemeBinding Light=#5B7288, Dark=#8BA4BE}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                Text="Photo"
                                BackgroundColor="#2E86AB"
                                TextColor="#FFFFFF"
                                Clicked="OnTakePhotoClicked"
                                SemanticProperties.Hint="Open the camera to capture a food image" />
                    </Grid>
                    <Border StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light=#E0F0FA, Dark=#1A2D3D}"
                            HeightRequest="220">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Grid>
                            <Image x:Name="FoodPhoto"
                                   Aspect="AspectFill"
                                   IsVisible="False"
                                   SemanticProperties.Description="Captured food photo preview" />
                            <VerticalStackLayout x:Name="PhotoFallback"
                                                 HorizontalOptions="Center"
                                                 VerticalOptions="Center"
                                                 Spacing="8">
                                <Label Text="🍽️"
                                       FontSize="48"
                                       HorizontalTextAlignment="Center" />
                                <Label Text="Tap Photo to capture"
                                       FontSize="15"
                                       TextColor="{AppThemeBinding Light=#8BA4BE, Dark=#5B7288}"
                                       HorizontalTextAlignment="Center" />
                                <Label x:Name="PhotoStatusLabel"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light=#8BA4BE, Dark=#5B7288}"
                                       HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#D0E4EE, Dark=#2A4055}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#162535}"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="3">
                            <Label Text="Meal location" FontSize="17" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#56C596, Dark=#56C596}" />
                            <Label Text="Show country, city, region, and coordinates." FontSize="13" TextColor="{AppThemeBinding Light=#5B7288, Dark=#8BA4BE}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                Text="Locate"
                                BackgroundColor="#56C596"
                                TextColor="#FFFFFF"
                                Clicked="OnGetLocationClicked"
                                SemanticProperties.Hint="Use location to record the meal place" />
                    </Grid>
                    <Label x:Name="LocationLabel"
                           Grid.Row="1"
                           Text="Location has not been captured yet."
                           FontSize="15"
                           TextColor="{AppThemeBinding Light=#5B7288, Dark=#8BA4BE}" />
                    <Label x:Name="CoordinateLabel"
                           Grid.Row="2"
                           Text="Coordinates will appear here."
                           FontSize="13"
                           TextColor="{AppThemeBinding Light=#8BA4BE, Dark=#5B7288}" />
                </Grid>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Text="Read help"
                        BackgroundColor="#45B7D1"
                        TextColor="#1B2838"
                        Clicked="OnReadHelpClicked"
                        SemanticProperties.Hint="Read the help text aloud" />
                <Button Grid.Column="1"
                        Text="Stop speech"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#162535}"
                        BorderColor="{AppThemeBinding Light=#D0E4EE, Dark=#2A4055}"
                        BorderWidth="1"
                        TextColor="{AppThemeBinding Light=#2E86AB, Dark=#5BC0EB}"
                        Clicked="OnStopSpeechClicked"
                        SemanticProperties.Hint="Stop current speech" />
            </Grid>

            <Button Text="Haptic feedback"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#162535}"
                    BorderColor="{AppThemeBinding Light=#D0E4EE, Dark=#2A4055}"
                    BorderWidth="1"
                    TextColor="{AppThemeBinding Light=#2E86AB, Dark=#5BC0EB}"
                    Clicked="OnFeedbackClicked"
                    SemanticProperties.Hint="Trigger vibration and haptic feedback" />

            <Border StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=#E0F0FA, Dark=#1A2D3D}"
                    Padding="14">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="6">
                    <Label x:Name="HardwareStatusLabel"
                           Text="Ready."
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#2E86AB, Dark=#5BC0EB}" />
                    <Label x:Name="FeedbackCountLabel"
                           Text="Haptic feedback tests: 0"
                           FontSize="13"
                           TextColor="{AppThemeBinding Light=#5B7288, Dark=#8BA4BE}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
