<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:FoodDrinkApp.Models"
             x:Class="FoodDrinkApp.MainPage"
             Title="NutriBite">

    <Grid RowDefinitions="Auto,Auto,Auto,*">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{AppThemeBinding Light=#E8F4F8, Dark=#0A1628}" Offset="0.0" />
                <GradientStop Color="{AppThemeBinding Light=#F0F7FA, Dark=#0D1B2A}" Offset="0.45" />
                <GradientStop Color="{AppThemeBinding Light=#F5FAFD, Dark=#0B1825}" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Header Banner -->
        <Grid Padding="20,18,20,18">
            <Border StrokeThickness="0" Padding="18">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{AppThemeBinding Light=#2E86AB, Dark=#1A3A4A}" Offset="0.0" />
                        <GradientStop Color="{AppThemeBinding Light=#45B7D1, Dark=#1A4A5A}" Offset="0.62" />
                        <GradientStop Color="{AppThemeBinding Light=#56C596, Dark=#1A4A40}" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Shadow>
                    <Shadow Brush="#33000000" Offset="0,8" Radius="18" Opacity="0.45" />
                </Border.Shadow>
                <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">
                    <Label Text="NutriBite"
                           FontSize="31"
                           FontAttributes="Bold"
                           TextColor="#FFFFFF"
                           SemanticProperties.HeadingLevel="Level1" />
                    <Label Grid.Row="1"
                           Text="Track nutrition, flavour, photos, and meal context in one place."
                           FontSize="15"
                           TextColor="#E8F4F8" />
                    <Grid Grid.Row="2" ColumnDefinitions="*,*,*" ColumnSpacing="8" Margin="0,3,0,0">
                        <Border BackgroundColor="#33FFFFFF" StrokeThickness="0" Padding="10,7">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Label Text="Nutrition" TextColor="#FFFFFF" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        </Border>
                        <Border Grid.Column="1" BackgroundColor="#33FFFFFF" StrokeThickness="0" Padding="10,7">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Label Text="Photos" TextColor="#FFFFFF" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        </Border>
                        <Border Grid.Column="2" BackgroundColor="#33FFFFFF" StrokeThickness="0" Padding="10,7">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Label Text="Voice" TextColor="#FFFFFF" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        </Border>
                    </Grid>
                    <Grid Grid.Row="3" ColumnDefinitions="*,Auto" ColumnSpacing="10" Margin="0,6,0,0">
                        <Border StrokeThickness="1"
                                Stroke="#D0E4EE"
                                BackgroundColor="#FFFFFF"
                                Padding="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <SearchBar x:Name="SearchFoodBar"
                                       Placeholder="Search foods, drinks, categories, or tags"
                                       TextChanged="OnSearchTextChanged"
                                       SearchButtonPressed="OnSearchButtonPressed"
                                       TextColor="#1B2838"
                                       PlaceholderColor="#8BA4BE"
                                       BackgroundColor="Transparent"
                                       SemanticProperties.Hint="Search the food and drink list" />
                        </Border>
                        <Button Grid.Column="1"
                                Text="Add"
                                BackgroundColor="#56C596"
                                TextColor="#FFFFFF"
                                FontAttributes="Bold"
                                Clicked="OnAddClicked"
                                SemanticProperties.Hint="Add a new food or drink record" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Nutrition Dashboard -->
        <Border Grid.Row="1"
                StrokeThickness="1"
                Stroke="{AppThemeBinding Light=#D0E4EE, Dark=#2A4055}"
                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#162535}"
                Padding="14,10"
                Margin="16,0,16,0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="8" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#22000000" Offset="0,4" Radius="12" Opacity="0.28" />
            </Border.Shadow>
            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                <!-- Calories -->
                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                    <Label Text="Calories"
                           FontSize="11"
                           TextColor="{AppThemeBinding Light=#5B7288, Dark=#8BA4BE}"
                           HorizontalTextAlignment="Center" />
                    <Label x:Name="DashCalories"
                           Text="0"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#2E86AB, Dark=#5BC0EB}"
                           HorizontalTextAlignment="Center" />
                    <Label Text="kcal"
                           FontSize="10"
                           TextColor="{AppThemeBinding Light=#5B7288, Dark=#8BA4BE}"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
                <!-- Protein -->
                <VerticalStackLayout Grid.Column="1" Spacing="2" HorizontalOptions="Center">
                    <Label Text="Protein"
                           FontSize="11"
                           TextColor="{AppThemeBinding Light=#5B7288, Dark=#8BA4BE}"
                           HorizontalTextAlignment="Center" />
                    <Label x:Name="DashProtein"
                           Text="0"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#45B7D1, Dark=#45B7D1}"
                           HorizontalTextAlignment="Center" />
                    <Label Text="g"
                           FontSize="10"
                           TextColor="{AppThemeBinding Light=#5B7288, Dark=#8BA4BE}"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
                <!-- Carbs -->
                <VerticalStackLayout Grid.Column="2" Spacing="2" HorizontalOptions="Center">
                    <Label Text="Carbs"
                           FontSize="11"
                           TextColor="{AppThemeBinding Light=#5B7288, Dark=#8BA4BE}"
                           HorizontalTextAlignment="Center" />
                    <Label x:Name="DashCarbs"
                           Text="0"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#56C596, Dark=#56C596}"
                           HorizontalTextAlignment="Center" />
                    <Label Text="g"
                           FontSize="10"
                           TextColor="{AppThemeBinding Light=#5B7288, Dark=#8BA4BE}"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
                <!-- Fat -->
                <VerticalStackLayout Grid.Column="3" Spacing="2" HorizontalOptions="Center">
                    <Label Text="Fat"
                           FontSize="11"
                           TextColor="{AppThemeBinding Light=#5B7288, Dark=#8BA4BE}"
                           HorizontalTextAlignment="Center" />
                    <Label x:Name="DashFat"
                           Text="0"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#FF6B6B, Dark=#FF6B6B}"
                           HorizontalTextAlignment="Center" />
                    <Label Text="g"
                           FontSize="10"
                           TextColor="{AppThemeBinding Light=#5B7288, Dark=#8BA4BE}"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <!-- Loading Indicator -->
        <HorizontalStackLayout Grid.Row="2"
                               x:Name="LoadingBar"
                               IsVisible="False"
                               HorizontalOptions="Center"
                               Padding="8,4"
                               Spacing="8">
            <ActivityIndicator IsRunning="True"
                               Color="{AppThemeBinding Light=#2E86AB, Dark=#5BC0EB}"
                               HeightRequest="20"
                               WidthRequest="20" />
            <Label Text="Loading food data..."
                   FontSize="13"
                   TextColor="{AppThemeBinding Light=#5B7288, Dark=#8BA4BE}"
                   VerticalOptions="Center" />
        </HorizontalStackLayout>

        <!-- Food List -->
        <RefreshView Grid.Row="3" x:Name="FoodRefreshView" Refreshing="OnRefreshing">
            <CollectionView x:Name="FoodCollection"
                            SelectionMode="None"
                            EmptyView="{x:Null}"
                            Margin="16,0,16,18">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:FoodItem">
                        <SwipeView>
                            <SwipeView.RightItems>
                                <SwipeItems>
                                    <SwipeItem Text="Delete"
                                               BackgroundColor="#FF5252"
                                               CommandParameter="{Binding Id}"
                                               Invoked="OnDeleteInvoked" />
                                </SwipeItems>
                            </SwipeView.RightItems>
                            <Border StrokeThickness="1"
                                Stroke="{AppThemeBinding Light=#D0E4EE, Dark=#2A4055}"
                                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#162535}"
                                Padding="0"
                                Margin="0,0,0,12">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#22000000" Offset="0,5" Radius="14" Opacity="0.34" />
                            </Border.Shadow>
                            <Grid ColumnDefinitions="6,*">
                                <BoxView BackgroundColor="{AppThemeBinding Light=#2E86AB, Dark=#5BC0EB}" />
                                <Grid Grid.Column="1" Padding="16" RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="8" ColumnSpacing="10">
                                    <Label Text="{Binding Name}"
                                           FontSize="20"
                                           FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=#1B2838, Dark=#E8F0F8}"
                                           SemanticProperties.HeadingLevel="Level2" />
                                    <Border Grid.Column="1"
                                            StrokeThickness="0"
                                            BackgroundColor="{AppThemeBinding Light=#E0F0FA, Dark=#1A3040}"
                                            Padding="10,5">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="8" />
                                        </Border.StrokeShape>
                                        <Label Text="{Binding CaloriesLabel}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light=#2E86AB, Dark=#5BC0EB}" />
                                    </Border>
                                    <Label Grid.Row="1"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding Description}"
                                           FontSize="14"
                                           TextColor="{AppThemeBinding Light=#5B7288, Dark=#8BA4BE}"
                                           LineBreakMode="TailTruncation" />
                                    <Label Grid.Row="2"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding MacroSummary}"
                                           FontSize="13"
                                           TextColor="{AppThemeBinding Light=#56C596, Dark=#56C596}" />
                                    <Grid Grid.Row="3" Grid.ColumnSpan="2" ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                                        <Label Text="{Binding Category}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light=#2E86AB, Dark=#5BC0EB}" />
                                        <Button Grid.Column="1"
                                                Text="Details"
                                                Padding="14,8"
                                                BackgroundColor="{AppThemeBinding Light=#2E86AB, Dark=#5BC0EB}"
                                                TextColor="#FFFFFF"
                                                CommandParameter="{Binding Id}"
                                                Clicked="OnDetailsClicked"
                                                SemanticProperties.Hint="Open nutrition details" />
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center"
                                         VerticalOptions="Center"
                                         Spacing="12"
                                         Padding="20">
                        <Label Text="No matching food or drink records."
                               FontSize="16"
                               TextColor="{AppThemeBinding Light=#5B7288, Dark=#8BA4BE}"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Try a different search term, or add a new entry."
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#8BA4BE, Dark=#5B7288}"
                               HorizontalTextAlignment="Center" />
                        <Button Text="Add New Record"
                                BackgroundColor="#56C596"
                                TextColor="#FFFFFF"
                                Clicked="OnAddClicked"
                                HorizontalOptions="Center"
                                SemanticProperties.Hint="Add a new food or drink record" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
