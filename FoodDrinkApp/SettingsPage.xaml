<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.SettingsPage"
             Title="Settings">
    <ScrollView>
        <ScrollView.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{AppThemeBinding Light=#E8F4F8, Dark=#0A1628}" Offset="0.0" />
                <GradientStop Color="{AppThemeBinding Light=#F0F7FA, Dark=#0D1B2A}" Offset="1.0" />
            </LinearGradientBrush>
        </ScrollView.Background>

        <VerticalStackLayout Padding="22" Spacing="16">
            <Border StrokeThickness="0" Padding="18" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#162535}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="6">
                    <Label Text="Accessibility settings"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#1B2838, Dark=#E8F0F8}"
                           SemanticProperties.HeadingLevel="Level1" />
                    <Label Text="Large text takes effect immediately and remains active when switching pages."
                           FontSize="15"
                           TextColor="{AppThemeBinding Light=#5B7288, Dark=#8BA4BE}" />
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#D0E4EE, Dark=#2A4055}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#162535}"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="16">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
                        <Label Text="Theme mode"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#2E86AB, Dark=#5BC0EB}" />
                        <Picker x:Name="ThemePicker"
                                Grid.Row="1"
                                Title="Choose app theme"
                                SelectedIndexChanged="OnThemeChanged"
                                SemanticProperties.Hint="Switch between system, light, and dark theme">
                            <Picker.Items>
                                <x:String>Use system theme</x:String>
                                <x:String>Light theme</x:String>
                                <x:String>Dark theme</x:String>
                            </Picker.Items>
                        </Picker>
                    </Grid>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#D0E4EE, Dark=#2A4055}" />

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Large text mode"
                                   FontSize="17"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#56C596, Dark=#56C596}" />
                            <Label Text="Increase text size for accessibility demonstration."
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light=#5B7288, Dark=#8BA4BE}" />
                        </VerticalStackLayout>
                        <Switch x:Name="LargeTextSwitch"
                                Grid.Column="1"
                                Toggled="OnLargeTextToggled"
                                SemanticProperties.Hint="Increase text size across the current session" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=#E0F0FA, Dark=#1A2D3D}"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <Label x:Name="LargeTextPreviewTitle"
                           Text="Large text preview"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#2E86AB, Dark=#5BC0EB}" />
                    <Label x:Name="LargeTextPreviewBody"
                           Text="When enabled, this text and the rest of the page become visibly larger."
                           FontSize="15"
                           TextColor="{AppThemeBinding Light=#5B7288, Dark=#8BA4BE}" />
                </VerticalStackLayout>
            </Border>

            <Label x:Name="SettingsStatusLabel"
                   Text="Settings ready."
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#2E86AB, Dark=#5BC0EB}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
