<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.AddItemPage"
             Title="Add Record">
    <ScrollView>
        <ScrollView.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{AppThemeBinding Light=#E8F4F8, Dark=#0A1628}" Offset="0.0" />
                <GradientStop Color="{AppThemeBinding Light=#F0F7FA, Dark=#0D1B2A}" Offset="1.0" />
            </LinearGradientBrush>
        </ScrollView.Background>
        <VerticalStackLayout Padding="22" Spacing="16">
            <Border StrokeThickness="0" Padding="18" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#162535}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Grid RowDefinitions="Auto,Auto" RowSpacing="6">
                    <Label Text="Add food or drink"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#1B2838, Dark=#E8F0F8}"
                           SemanticProperties.HeadingLevel="Level1" />
                    <Label Grid.Row="1"
                           Text="Record the full details of a meal worth remembering."
                           FontSize="15"
                           TextColor="{AppThemeBinding Light=#5B7288, Dark=#8BA4BE}" />
                </Grid>
            </Border>

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#D0E4EE, Dark=#2A4055}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#162535}"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="14">
                    <Label Text="Basic information" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#2E86AB, Dark=#5BC0EB}" />
                    <Entry x:Name="NameEntry"
                           Placeholder="Name"
                           SemanticProperties.Hint="Required food or drink name" />
                    <Picker x:Name="CategoryPicker"
                            Title="Category"
                            SemanticProperties.Hint="Required category">
                        <Picker.Items>
                            <x:String>Breakfast</x:String>
                            <x:String>Lunch</x:String>
                            <x:String>Dinner</x:String>
                            <x:String>Snack</x:String>
                            <x:String>Drink</x:String>
                        </Picker.Items>
                    </Picker>
                    <Editor x:Name="DescriptionEditor"
                            Placeholder="Description, ingredients, flavour, or context"
                            AutoSize="TextChanges"
                            HeightRequest="104"
                            SemanticProperties.Hint="Describe this food or drink" />
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#D0E4EE, Dark=#2A4055}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#162535}"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="14">
                    <Label Text="Nutrition data" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#56C596, Dark=#56C596}" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Entry x:Name="CaloriesEntry"
                               Placeholder="Calories"
                               Keyboard="Numeric"
                               SemanticProperties.Hint="Required calories as a number" />
                        <Entry x:Name="ProteinEntry"
                               Grid.Column="1"
                               Placeholder="Protein g"
                               Keyboard="Numeric" />
                    </Grid>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Entry x:Name="CarbsEntry"
                               Placeholder="Carbs g"
                               Keyboard="Numeric" />
                        <Entry x:Name="FatEntry"
                               Grid.Column="1"
                               Placeholder="Fat g"
                               Keyboard="Numeric" />
                    </Grid>
                    <Entry x:Name="AllergyEntry"
                           Placeholder="Allergy note or dietary restriction"
                           SemanticProperties.Hint="Enter allergy or dietary information" />
                </VerticalStackLayout>
            </Border>

            <Border x:Name="ValidationPanel"
                    IsVisible="False"
                    StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=#FFEBEE, Dark=#3A2020}"
                    Padding="14">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Label x:Name="ValidationLabel"
                       TextColor="{AppThemeBinding Light=#C62828, Dark=#FFCDD2}"
                       FontAttributes="Bold" />
            </Border>

            <Button Text="Save record"
                    FontAttributes="Bold"
                    BackgroundColor="#2E86AB"
                    TextColor="#FFFFFF"
                    Clicked="OnSaveClicked"
                    SemanticProperties.Hint="Validate and save this record" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
