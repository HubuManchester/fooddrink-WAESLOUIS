<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FoodDrinkApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:FoodDrinkApp"
    Title="NutriBite"
    FlyoutBehavior="Disabled"
    Shell.BackgroundColor="{AppThemeBinding Light=#E8F0F8, Dark=#0A1628}"
    Shell.ForegroundColor="{AppThemeBinding Light=#1B2838, Dark=#E8F0F8}"
    Shell.TitleColor="{AppThemeBinding Light=#1B2838, Dark=#E8F0F8}"
    Shell.UnselectedColor="{AppThemeBinding Light=#8BA4BE, Dark=#5B7288}"
    Shell.TabBarBackgroundColor="{AppThemeBinding Light=#E8F0F8, Dark=#0A1628}"
    Shell.TabBarForegroundColor="{AppThemeBinding Light=#2E86AB, Dark=#5BC0EB}"
    Shell.TabBarTitleColor="{AppThemeBinding Light=#2E86AB, Dark=#5BC0EB}"
    Shell.TabBarUnselectedColor="{AppThemeBinding Light=#8BA4BE, Dark=#5B7288}">

    <TabBar>
        <ShellContent
            Title="Foods"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage" />
        <ShellContent
            Title="Hardware"
            ContentTemplate="{DataTemplate local:HardwarePage}"
            Route="HardwarePage" />
        <ShellContent
            Title="Settings"
            ContentTemplate="{DataTemplate local:SettingsPage}"
            Route="SettingsPage" />
    </TabBar>
</Shell>
